{
  "buildCommand": null,
  "outputDirectory": ".",
  "functions": {
    "api/download.js": {
      "maxDuration": 10
    },
    "api/stats.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
